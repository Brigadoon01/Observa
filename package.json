{
  "name": "@jeremiah01/observa",
  "version": "1.0.2",
  "description": "Production-grade observability SDK for Node.js — logging, tracing, alerting",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "keywords": [
    "observability",
    "logging",
    "tracing",
    "alerting",
    "opentelemetry",
    "nodejs"
  ],
  "license": "MIT",
  "dependencies": {
    "@jeremiah01/observa": "^1.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "jsonwebtoken": "^9.0.3",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "globals": "^17.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "express": "^5.2.1"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  }
}
